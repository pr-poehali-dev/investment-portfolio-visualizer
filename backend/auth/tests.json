{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {
        "email": "test@example.com",
        "password": "testpass123",
        "name": "Test User"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "user": {
          "email": "string",
          "name": "string"
        },
        "token": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "test@example.com",
        "password": "testpass123"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "user": {
          "email": "string"
        },
        "token": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot password - unknown email",
      "method": "POST",
      "path": "/?action=forgot-password",
      "body": {
        "email": "nonexistent@example.com"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "message": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Reset password - invalid token",
      "method": "POST",
      "path": "/?action=reset-password",
      "body": {
        "token": "invalidtoken",
        "new_password": "newpassword123"
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    }
  ]
}